# =============================================================================
# SUT Smart Bus Monorepo - Git Ignore
# =============================================================================

# ── Node / Expo (apps/mobile) ──────────────────────────────────────────────
node_modules/
.expo/
dist/
*.tsbuildinfo
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python (server) ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
venv/
.venv/
env/
.env

# ── Arduino / PlatformIO (hardware) ───────────────────────────────────────
.pio/
.vscode/
*.o
*.elf
*.hex
*.bin

# ── Docker ─────────────────────────────────────────────────────────────────
*.log

# ── IDE / OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
*.iml
