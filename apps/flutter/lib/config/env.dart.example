/// Environment configuration example
/// Copy this file to env.dart and edit with your actual settings
class Env {
  /// 'local' or 'tunnel'
  static const String connectionMode = 'local';

  /// Public URL if using tunnel (e.g. https://api.sutbus.com)
  static const String apiUrl = 'http://localhost:8000';

  /// Local IP of the server if using local mode
  static const String serverIp = 'localhost';

  /// API Port
  static const int apiPort = 8000;

  /// MQTT Broker Host
  static const String mqttBrokerHost = 'localhost';

  /// MQTT TCP Port (for native apps)
  static const int mqttBrokerPort = 1883;

  /// MQTT WebSocket Port (for web and some proxy setups)
  static const int mqttWebSocketPort = 9001;

  /// API Secret Key (matches server's API_SECRET_KEY)
  static const String apiSecretKey = '94dc28a9d3917361f6f2e39851136873c2937559587418936777bf59e07d7228';

  static bool get isTunnelMode => connectionMode == 'tunnel';
}
